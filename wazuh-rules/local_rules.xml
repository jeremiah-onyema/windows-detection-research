<!-- Merged 2026-07-07: full Sigma coverage (T1543/T1053/T1547/T1546/T1071/T1027). -->
<!-- Stock example sshd rule removed; 100001 reused for T1543.003 baseline.        -->

<group name="windows,persistence,sigma_coverage,">

  <!-- ================= T1543.003 Service Installation ================= -->
  <!-- Anchored to default 7045 rule 61138 so this evaluates as its child      -->
  <!-- (a standalone field-match rule loses the event to 61138 in production). -->
  <rule id="100001" level="12">
    <if_sid>61138</if_sid>
    <description>New Windows Service Installed: $(win.eventdata.serviceName)</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
  </rule>


  <rule id="100002" level="15">
    <if_sid>100001</if_sid>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)\\Users\\|\\Downloads\\|\\AppData\\|\\Temp\\|\\ProgramData\\|\\Public\\</field>
    <description>High Risk: Service installed from suspicious path: $(win.eventdata.imagePath)</description>
    <mitre>
      <id>T1543.003</id>
    </mitre>
  </rule>

  <!-- ================= T1071.004 DNS C2 ================= -->
  <!-- --dns server= survives binary rename; cannot change without breaking tool -->
  <rule id="100003" level="15">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)--dns</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)server=</field>
    <description>CRITICAL: DNS C2 tool detected via command-line arguments: $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1071.004</id>
    </mitre>
  </rule>

  <!-- ================= T1053.005 Scheduled Task ================= -->
  <rule id="100005" level="12">
    <if_sid>60228</if_sid>
    <description>Scheduled task created: $(win.eventdata.taskName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
  </rule>

  <rule id="100006" level="15">
    <if_sid>100005</if_sid>
    <field name="win.eventdata.taskContent" type="pcre2">(?i)cmd\.exe|powershell\.exe|wscript\.exe|mshta\.exe|rundll32\.exe|regsvr32\.exe|cscript\.exe|certutil|bitsadmin</field>
    <description>High Risk: Scheduled task running suspicious executable: $(win.eventdata.taskName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
  </rule>

  <rule id="100007" level="13">
    <if_sid>100005</if_sid>
    <field name="win.eventdata.taskContent" type="pcre2">(?i)BootTrigger|LogonTrigger</field>
    <description>Persistence: Scheduled task triggers on boot or logon: $(win.eventdata.taskName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
  </rule>

  <!-- taskContent is HTML-encoded in Wazuh: <Hidden>true</Hidden> arrives as    -->
  <!-- &lt;Hidden&gt;true... so allow the encoded '&gt;' (up to 8 chars) between. -->
  <rule id="100008" level="15">
    <if_sid>100005</if_sid>
    <field name="win.eventdata.taskContent" type="pcre2">(?i)Hidden.{0,8}true</field>
    <description>Critical: Hidden scheduled task created: $(win.eventdata.taskName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
  </rule>

  <rule id="100009" level="15">
    <if_sid>100005</if_sid>
    <field name="win.eventdata.taskContent" type="pcre2">(?i)\\Downloads\\|\\AppData\\|\\Temp\\|\\Desktop\\|\\Public\\</field>
    <description>High Risk: Scheduled task executes from suspicious path: $(win.eventdata.taskName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
  </rule>

  <!-- HighestAvailable privilege + boot/logon trigger = high-confidence persistence+privesc -->
  <rule id="100010" level="15">
    <if_sid>100007</if_sid>
    <field name="win.eventdata.taskContent" type="pcre2">(?i)HighestAvailable</field>
    <description>CRITICAL: Scheduled task runs at highest privilege on boot/logon: $(win.eventdata.taskName)</description>
    <mitre>
      <id>T1053.005</id>
    </mitre>
  </rule>

  <!-- ================= T1547.001 Registry Run Key / Winlogon ================= -->
  <rule id="100011" level="12">
    <if_sid>92300</if_sid>
    <description>Registry Run key persistence: $(win.eventdata.targetObject) written by $(win.eventdata.image)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
  </rule>

  <rule id="100012" level="15">
    <if_sid>100011</if_sid>
    <field name="win.eventdata.details" type="pcre2">(?i)powershell|cmd\.exe|wscript|mshta|rundll32|regsvr32|hidden|bypass|encoded|downloadstring|iex|invoke</field>
    <description>High Risk: Suspicious command written to Run key by $(win.eventdata.image): $(win.eventdata.targetObject)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
  </rule>

  <!-- Catches secedit LOLBIN persistence: write attributed to services.exe, not reg.exe -->
  <rule id="100013" level="15">
    <if_sid>100011</if_sid>
    <field name="win.eventdata.image" type="pcre2" negate="yes">(?i)reg\.exe|msiexec\.exe|setup\.exe|install</field>
    <field name="win.eventdata.details" type="pcre2">(?i)\.(exe|bat|cmd|ps1|vbs|js|hta|dll)</field>
    <description>High Risk: Unexpected process wrote executable to Run key: $(win.eventdata.image)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
  </rule>

  <rule id="100014" level="15">
    <if_group>sysmon_event_13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)winlogon\\\\userinit|winlogon\\\\shell</field>
    <description>CRITICAL: Winlogon persistence key modified by $(win.eventdata.image): $(win.eventdata.targetObject)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
  </rule>

  <!-- ================= T1547.009 Startup Folder ================= -->
  <rule id="100015" level="14">
    <if_group>sysmon_event_11</if_group>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\\\Microsoft\\\\Windows\\\\Start Menu\\\\Programs\\\\Startup\\\\.+\.(lnk|url)</field>
    <options>no_full_log</options>
    <description>Startup folder persistence: $(win.eventdata.targetFilename) created by $(win.eventdata.image)</description>
    <mitre>
      <id>T1547.009</id>
    </mitre>
  </rule>

  <rule id="100016" level="15">
    <if_sid>100015</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell\.exe|cmd\.exe|wscript\.exe|mshta\.exe|cscript\.exe|rundll32\.exe</field>
    <options>no_full_log</options>
    <description>High Risk: Suspicious process created startup shortcut: $(win.eventdata.image) wrote $(win.eventdata.targetFilename)</description>
    <mitre>
      <id>T1547.009</id>
    </mitre>
  </rule>

  <!-- ================= T1546.003 WMI Event Subscription ================= -->
  <!-- 100017: Event Filter querying system uptime (boot-persistence trigger) -->
  <rule id="100017" level="13">
    <if_group>sysmon_event_19</if_group>
    <field name="win.eventdata.query" type="pcre2">(?i)SystemUpTime|Win32_PerfFormattedData_PerfOS_System</field>
    <description>WMI event filter using system uptime trigger: $(win.eventdata.name)</description>
    <mitre>
      <id>T1546.003</id>
    </mitre>
  </rule>

  <!-- 100018: CommandLine Event Consumer registered -->
  <rule id="100018" level="13">
    <if_group>sysmon_event_20</if_group>
    <field name="win.eventdata.type" type="pcre2">(?i)Command Line</field>
    <description>WMI CommandLine event consumer registered: $(win.eventdata.name)</description>
    <mitre>
      <id>T1546.003</id>
    </mitre>
  </rule>

  <!-- 100019: ActiveScript Event Consumer registered (fileless, no disk artifact) -->
  <!-- NOTE: Sysmon Event 20 reports the ActiveScript consumer Type as 'Script'    -->
  <!-- (not 'Active Script' as the Sigma source assumed). Verified on-box 2026-07.  -->
  <rule id="100019" level="15">
    <if_group>sysmon_event_20</if_group>
    <field name="win.eventdata.type" type="pcre2">(?i)^Script$</field>
    <description>CRITICAL: WMI ActiveScript event consumer registered (fileless persistence): $(win.eventdata.name)</description>
    <mitre>
      <id>T1546.003</id>
    </mitre>
  </rule>

  <!-- 100020: Filter-to-Consumer binding created (arms the persistence) -->
  <rule id="100020" level="15">
    <if_group>sysmon_event_21</if_group>
    <field name="win.eventdata.consumer" type="pcre2" negate="yes">(?i)BVTConsumer|SCM Event Log Consumer|Microsoft</field>
    <description>CRITICAL: WMI filter-to-consumer binding created (persistence armed): $(win.eventdata.consumer)</description>
    <mitre>
      <id>T1546.003</id>
    </mitre>
  </rule>

  <!-- 100021: mofcomp.exe compiling a MOF from a user-writable path (LOLBIN WMI    -->
  <!-- install). Verified 2026-07-09: original Sigma negate on 'system32\wbem' is    -->
  <!-- defeated by mofcomp's OWN binary path; and "not in wbem" false-positives on   -->
  <!-- legit Defender MOFs in ProgramData. Positive-match on user-writable MOF paths -->
  <!-- is the defensible heuristic. mofcomp is a supplementary signal - the strong   -->
  <!-- detections are the WMI subscription rules 100017-100020.                      -->
  <rule id="100021" level="13">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\mofcomp\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\\Users\\|\\Downloads\\|\\AppData\\|\\Temp\\|\\Desktop\\|\\Public\\</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\.mof</field>
    <description>WMI persistence via mofcomp.exe compiling MOF from user-writable path: $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1546.003</id>
    </mitre>
  </rule>

</group>

<group name="windows,powershell,obfuscation,t1027,">

  <!-- Rule 100100: Numeric base conversion + char assembly (base-agnostic) -->
  <rule id="100100" level="12">
  <if_group>sysmon_event1</if_group>
  <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe</field>
  <field name="win.eventdata.commandLine" type="pcre2">(?i)t`?o`?i`?n`?t`?(16|32|64).{0,500}\[char\]|\[char\].{0,500}t`?o`?i`?n`?t`?(16|32|64)</field>
  <description>PowerShell numeric-to-character conversion pipeline detected - possible base-agnostic obfuscation (T1027)</description>
  <mitre>
    <id>T1027</id>
    <id>T1059.001</id>
  </mitre>
  <group>powershell_obfuscation,defense_evasion,</group>
</rule>

  <!-- Rule 100101: Dynamic IEX construction via format strings -->
  <rule id="100101" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\[type\]</field>
    <field name="win.eventdata.commandLine" type="pcre2">\s-f\s?</field>
    <description>PowerShell dynamic type construction with format string assembly - defeats Script Block Logging deobfuscation (T1027)</description>
    <mitre>
      <id>T1027</id>
      <id>T1059.001</id>
    </mitre>
    <group>powershell_obfuscation,defense_evasion,</group>
  </rule>

  <!-- Rule 100102: PS->PS spawning + obfuscation indicators -->
  <rule id="100102" level="13">
  <if_group>sysmon_event1</if_group>
  <field name="win.eventdata.image" type="pcre2">(?i)\\powershell\.exe</field>
  <field name="win.eventdata.parentImage" type="pcre2">(?i)\\powershell\.exe</field>
  <field name="win.eventdata.commandLine" type="pcre2">(?i)(t`?o`?i`?n`?t`?(16|32|64)|\[type\].{0,200}-f|\[char\].{0,200}t`?o`?i`?n`?t`?)</field>
  <description>PowerShell spawned PowerShell with obfuscation indicators - high-confidence T1027 detection</description>
  <mitre>
    <id>T1027</id>
    <id>T1059.001</id>
  </mitre>
  <group>powershell_obfuscation,defense_evasion,</group>
</rule>

</group>
